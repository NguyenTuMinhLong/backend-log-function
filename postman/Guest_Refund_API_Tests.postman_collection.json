							"pm.test('Response has refund details', function() {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.data).to.have.property('refund_code');",
							"    pm.expect(jsonData.data).to.have.property('status');",
							"    pm.expect(jsonData.data).to.have.property('booking_code');",
							"    pm.expect(jsonData.data.status).to.equal('pending');",
