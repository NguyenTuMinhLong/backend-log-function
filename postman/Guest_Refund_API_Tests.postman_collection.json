{
	"info": {
		"name": "Guest Refund API Tests",
		"description": "Postman collection for testing Guest Refund functionality",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Guest Refund - Create Refund Request",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 201', function() {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test('Response has refund_code', function() {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.data).to.have.property('refund_code');",
							"    pm.expect(jsonData.data.refund_code).to.match(/^REF-\\d{8}-[A-Z0-9]{6}$/);",
							"    ",
							"    // Store refund code for later tests",
							"    pm.collectionVariables.set('guest_refund_code', jsonData.data.refund_code);",
							"});",
							"",
							"pm.test('Response has refund_preview', function() {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.data).to.have.property('refund_preview');",
							"    pm.expect(jsonData.data.refund_preview).to.have.property('refund_amount');",
							"    pm.expect(jsonData.data.refund_preview).to.have.property('admin_fee');",
							"    pm.expect(jsonData.data.refund_preview).to.have.property('net_refund_amount');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "x-guest-session",
						"value": "guest-session-{{$timestamp}}-abc123",
						"type": "text",
						"description": "Optional guest session ID"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"bookingCode\": \"BK20250501001\",\n    \"guestEmail\": \"guest@example.com\",\n    \"refund_type\": \"full\",\n    \"reason\": \"Tôi muốn hủy chuyến bay vì kế hoạch thay đổi\",\n    \"user_notes\": \"Xin vui lòng hoàn tiền sớm nhất có thể\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/refunds/guest",
					"host": ["{{base_url}}"],
					"path": ["api", "refunds", "guest"]
				},
				"description": "Create a guest refund request - requires valid booking code and matching email"
			},
			"response": []
		},
