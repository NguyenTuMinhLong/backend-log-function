						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/refunds/guest/{{guest_refund_code}}?email=john.doe@example.com",
					"host": ["{{base_url}}"],
					"path": ["api", "refunds", "guest", "{{guest_refund_code}}"],
					"query": [
						{
							"key": "email",
							"value": "john.doe@example.com"
						}
					]
				},
				"description": "Get guest refund detail - requires email verification"
			},
