                "user",
                "verify-otp"
              ]
            }
          }
        },
        {
          "name": "3. [USER] Submit Refund",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var body = pm.response.json();",
                  "    var data = body.data || {};",
                  "    console.log('Refund submit response:', body);",
                  "    if (data.refund_code) pm.collectionVariables.set('refundCode', data.refund_code);",
                  "}"
