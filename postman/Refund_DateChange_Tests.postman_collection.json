                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingCode\": \"{{bookingCode}}\",\n  \"refund_type\": \"full\",\n  \"reason\": \"Khong con nhu cau di chuyen\",\n  \"user_notes\": \"Test submit refund tu Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/refunds/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "refunds",
                "user"
              ]
            }
          }
        },
