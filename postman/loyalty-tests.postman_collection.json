    {
      "name": "6 — Cron Annual Reset",
      "item": [
        {
          "name": "6.1 Trigger cron thủ công",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('base_url') + '/api/loyalty/membership',",
                  "  method: 'GET',",
                  "  header: { 'Authorization': pm.collectionVariables.get('token') }",
                  "}, (err, res) => {",
                  "  if (!err && res.json().data) {",
                  "    const d = res.json().data;",
                  "    pm.collectionVariables.set('tier_before_cron', d.tier);",
                  "    pm.collectionVariables.set('tier_pts_before_cron', d.tier_points);",
                  "    pm.collectionVariables.set('current_before_cron', d.current_points);",
                  "    pm.collectionVariables.set('lifetime_before_cron', d.lifetime_points);",
                  "    console.log('Before cron:', d.tier, '|', d.tier_points, 'pts');",
                  "  }",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Có message', () => pm.expect(res.data.message).to.be.a('string'));",
                  "console.log('Cron result:', JSON.stringify(res.data));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Cron-Secret", "value": "{{cron_secret}}" }
            ],
            "url": "{{base_url}}/api/loyalty/admin/trigger-annual-reset",
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "6.2 Verify sau cron — tier_points giảm 20%, lifetime KHÔNG đổi",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const d = res.data;",
                  "const tierPtsBefore  = parseInt(pm.collectionVariables.get('tier_pts_before_cron'));",
                  "const currentBefore  = parseInt(pm.collectionVariables.get('current_before_cron'));",
                  "const lifetimeBefore = parseInt(pm.collectionVariables.get('lifetime_before_cron'));",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "if (tierPtsBefore > 0) {",
                  "  const expected = Math.floor(tierPtsBefore * 0.8);",
                  "  pm.test('tier_points giảm đúng 20%', () => pm.expect(d.tier_points).to.eql(expected));",
                  "}",
                  "",
                  "pm.test('current_points KHÔNG đổi sau cron', () => pm.expect(d.current_points).to.eql(currentBefore));",
                  "pm.test('lifetime_points KHÔNG đổi sau cron', () => pm.expect(d.lifetime_points).to.eql(lifetimeBefore));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/api/loyalty/membership"
          }
        },
        {
          "name": "6.3 Cron — sai secret key (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "const res = pm.response.json();",
                  "pm.test('Có message lỗi', () => pm.expect(res.message).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Cron-Secret", "value": "WRONG_SECRET" }
            ],
            "url": "{{base_url}}/api/loyalty/admin/trigger-annual-reset",
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        }
      ]
    },

