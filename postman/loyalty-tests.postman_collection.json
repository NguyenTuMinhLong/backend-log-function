{
  "info": {
    "name": "Vivudee — Loyalty System API",
    "description": "Full test suite cho loyalty system: earn, redeem, revoke, cron, edge cases",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "user_id", "value": "1", "type": "string" },
    { "key": "token", "value": "Bearer YOUR_JWT_HERE", "type": "string" },
    { "key": "cron_secret", "value": "CRON_SECRET_KEY", "type": "string" },
    { "key": "test_booking_id", "value": "", "type": "string" },
    { "key": "membership_number", "value": "", "type": "string" },
    { "key": "reward_id", "value": "", "type": "string" },
    { "key": "voucher_code", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [

    {
      "name": "0 — Setup & Auth",
      "item": [
        {
          "name": "0.1 Login lấy token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', 'Bearer ' + res.token);",
                  "  if (res.user) pm.collectionVariables.set('user_id', res.user.id);",
                  "  console.log('Token saved:', res.token.slice(0,20) + '...');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Có token', () => pm.expect(res.token).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@vivudee.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "1 — Membership Info",
      "item": [
        {
          "name": "1.1 GET membership — user mới (tự tạo Member)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Có data', () => pm.expect(res.data).to.be.an('object'));",
                  "pm.test('Có membership_number', () => pm.expect(res.data.membership_number).to.match(/^VVD/));",
                  "pm.test('Tier mặc định là Member', () => pm.expect(res.data.tier).to.eql('Member'));",
                  "pm.test('lifetime_points = 0', () => pm.expect(res.data.lifetime_points).to.eql(0));",
                  "pm.test('tier_points = 0', () => pm.expect(res.data.tier_points).to.eql(0));",
                  "pm.test('current_points = 0', () => pm.expect(res.data.current_points).to.eql(0));",
                  "pm.test('progress = 0', () => pm.expect(res.data.progress).to.eql(0));",
                  "pm.test('next_tier là Silver', () => pm.expect(res.data.next_tier.name).to.eql('Silver'));",
                  "pm.test('multiplier = 1', () => pm.expect(res.data.multiplier).to.eql(1));",
                  "pm.collectionVariables.set('membership_number', res.data.membership_number);",
                  "console.log('Membership:', JSON.stringify(res.data, null, 2));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/api/loyalty/membership"
          }
        },
        {
          "name": "1.2 GET membership — gọi lại (không tạo duplicate)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('membership_number giống lần trước', () => {",
                  "  pm.expect(res.data.membership_number).to.eql(pm.collectionVariables.get('membership_number'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/api/loyalty/membership"
          }
        },
        {
          "name": "1.3 GET membership — với query userId (không cần auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Có data', () => pm.expect(res.data).to.be.an('object'));",
                  "pm.test('Có tier', () => pm.expect(res.data.tier).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/loyalty/membership?userId={{user_id}}",
              "query": [
                { "key": "userId", "value": "{{user_id}}" }
              ]
            }
          }
        }
      ]
    },

    {
      "name": "2 — Earn Points",
      "item": [
        {
          "name": "2.1 Earn — booking 500k (50 điểm × 1.0)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('test_booking_id', 'BK-' + Date.now());",
                  "console.log('Booking ID:', pm.collectionVariables.get('test_booking_id'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Có data', () => pm.expect(res.data).to.be.an('object'));",
                  "pm.test('pointsEarned = 50', () => pm.expect(res.data.pointsEarned).to.eql(50));",
                  "pm.test('alreadyEarned = false', () => pm.expect(res.data.alreadyEarned).to.be.false);",
                  "pm.collectionVariables.set('last_booking_id', pm.collectionVariables.get('test_booking_id'));",
                  "console.log('Earn result:', JSON.stringify(res.data));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/earn",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{test_booking_id}}\",\n  \"totalPrice\": 500000\n}"
            }
          }
        },
        {
          "name": "2.2 Earn — kiểm tra 3 cột sau khi earn",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('lifetime_points tăng', () => pm.expect(res.data.lifetime_points).to.be.above(0));",
                  "pm.test('tier_points tăng', () => pm.expect(res.data.tier_points).to.be.above(0));",
                  "pm.test('current_points tăng', () => pm.expect(res.data.current_points).to.be.above(0));",
                  "pm.test('3 cột bằng nhau sau earn đầu tiên', () => {",
                  "  const d = res.data;",
                  "  pm.expect(d.lifetime_points).to.eql(d.tier_points);",
                  "  pm.expect(d.tier_points).to.eql(d.current_points);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/api/loyalty/membership"
          }
        },
        {
          "name": "2.3 Earn — idempotent (cùng bookingId không tích 2 lần)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('alreadyEarned = true', () => pm.expect(res.data.alreadyEarned).to.be.true);",
                  "pm.test('pointsEarned = 0', () => pm.expect(res.data.pointsEarned).to.eql(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/earn",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{last_booking_id}}\",\n  \"totalPrice\": 500000\n}"
            }
          }
        },
        {
          "name": "2.4 Earn — booking giá thấp < 10k (0 điểm)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('pointsEarned = 0 khi giá < 10k', () => pm.expect(res.data.pointsEarned).to.eql(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/earn",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"BK-LOW-PRICE-001\",\n  \"totalPrice\": 5000\n}"
            }
          }
        },
        {
          "name": "2.5 Earn — booking lớn đủ lên Silver (5000 điểm)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('tier_up_booking_id', 'BK-TIER-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('pointsEarned >= 5000', () => pm.expect(res.data.pointsEarned).to.be.at.least(5000));",
                  "pm.collectionVariables.set('tier_up_booking_id_saved', pm.collectionVariables.get('tier_up_booking_id'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/earn",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{tier_up_booking_id}}\",\n  \"totalPrice\": 50000000\n}"
            }
          }
        },
        {
          "name": "2.6 Verify — đã lên Silver sau 2.5",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tier đã lên Silver', () => pm.expect(res.data.tier).to.eql('Silver'));",
                  "pm.test('multiplier = 1.25', () => pm.expect(res.data.multiplier).to.eql(1.25));",
                  "pm.test('next_tier là Gold', () => pm.expect(res.data.next_tier.name).to.eql('Gold'));",
                  "pm.test('progress > 0', () => pm.expect(res.data.progress).to.be.above(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/api/loyalty/membership"
          }
        }
      ]
    },

    {
      "name": "3 — Redeem Reward",
      "item": [
        {
          "name": "3.1 GET rewards — danh sách available",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Có data array', () => pm.expect(res.data).to.be.an('array'));",
                  "if (res.data.length > 0) {",
                  "  pm.test('Có points_required', () => pm.expect(res.data[0].points_required).to.be.a('number'));",
                  "  pm.collectionVariables.set('reward_id', res.data[0].id);",
                  "  console.log('Rewards:', res.data);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/api/loyalty/rewards"
          }
        },
        {
          "name": "3.2 Redeem — thành công",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success = true', () => pm.expect(res.data.success).to.be.true);",
                  "pm.test('Có voucherCode', () => pm.expect(res.data.voucherCode).to.match(/^VOUCHER-/));",
                  "pm.test('pointsRemaining là số', () => pm.expect(res.data.pointsRemaining).to.be.a('number'));",
                  "pm.test('pointsRemaining không âm', () => pm.expect(res.data.pointsRemaining).to.be.at.least(0));",
                  "pm.collectionVariables.set('voucher_code', res.data.voucherCode);",
                  "console.log('Redeem result:', JSON.stringify(res.data, null, 2));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/redeem",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rewardId\": {{reward_id}}\n}"
            }
          }
        },
        {
          "name": "3.3 Verify — tier_points KHÔNG đổi sau redeem",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('base_url') + '/api/loyalty/membership',",
                  "  method: 'GET',",
                  "  header: { 'Authorization': pm.collectionVariables.get('token') }",
                  "}, (err, res) => {",
                  "  if (!err && res.json().data) {",
                  "    const d = res.json().data;",
                  "    pm.collectionVariables.set('tier_before_redeem', d.tier);",
                  "    pm.collectionVariables.set('lifetime_before_redeem', d.lifetime_points);",
                  "  }",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const d = res.data;",
                  "const lifetimeBefore = parseInt(pm.collectionVariables.get('lifetime_before_redeem') || '0');",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (lifetimeBefore > 0) {",
                  "  pm.test('lifetime_points không đổi sau redeem', () => pm.expect(d.lifetime_points).to.eql(lifetimeBefore));",
                  "}",
                  "",
                  "const tierBefore = pm.collectionVariables.get('tier_before_redeem');",
                  "pm.test('tier không bị tụt sau redeem', () => {",
                  "  if (tierBefore) pm.expect(d.tier).to.eql(tierBefore);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/api/loyalty/membership"
          }
        },
        {
          "name": "3.4 Redeem — không đủ điểm (expect lỗi)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "const res = pm.response.json();",
                  "pm.test('Có message lỗi điểm', () => pm.expect(res.message).to.include('Không đủ điểm'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/redeem",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rewardId\": 99999\n}"
            }
          }
        },
        {
          "name": "3.5 Redeem — reward không tồn tại (expect lỗi)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 hoặc 404', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
                  "});",
                  "const res = pm.response.json();",
                  "pm.test('Có message lỗi', () => pm.expect(res.message).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/redeem",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rewardId\": 0\n}"
            }
          }
        }
      ]
    },

    {
      "name": "4 — Revoke Points (Cancel / Refund)",
      "item": [
        {
          "name": "4.1 Revoke — huỷ booking đã có điểm",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('base_url') + '/api/loyalty/membership',",
                  "  method: 'GET',",
                  "  header: { 'Authorization': pm.collectionVariables.get('token') }",
                  "}, (err, res) => {",
                  "  if (!err && res.json().data) {",
                  "    const d = res.json().data;",
                  "    pm.collectionVariables.set('tier_points_before_revoke', d.tier_points);",
                  "    pm.collectionVariables.set('current_before_revoke', d.current_points);",
                  "    pm.collectionVariables.set('lifetime_before_revoke', d.lifetime_points);",
                  "    pm.collectionVariables.set('tier_before_revoke', d.tier);",
                  "  }",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('pointsRevoked > 0', () => pm.expect(res.data.pointsRevoked).to.be.above(0));",
                  "console.log('Points revoked:', res.data.pointsRevoked);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/revoke",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{tier_up_booking_id_saved}}\"\n}"
            }
          }
        },
        {
          "name": "4.2 Verify — sau revoke: tier và current giảm, lifetime KHÔNG đổi",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const d = res.data;",
                  "const tierBefore     = parseInt(pm.collectionVariables.get('tier_points_before_revoke'));",
                  "const currentBefore  = parseInt(pm.collectionVariables.get('current_before_revoke'));",
                  "const lifetimeBefore = parseInt(pm.collectionVariables.get('lifetime_before_revoke'));",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('tier_points đã giảm', () => pm.expect(d.tier_points).to.be.below(tierBefore));",
                  "pm.test('current_points đã giảm', () => pm.expect(d.current_points).to.be.below(currentBefore));",
                  "pm.test('lifetime_points KHÔNG đổi', () => pm.expect(d.lifetime_points).to.eql(lifetimeBefore));",
                  "pm.test('tier_points không âm', () => pm.expect(d.tier_points).to.be.at.least(0));",
                  "pm.test('current_points không âm', () => pm.expect(d.current_points).to.be.at.least(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "url": "{{base_url}}/api/loyalty/membership"
          }
        },
        {
          "name": "4.3 Revoke — booking chưa từng earn điểm (expect 0)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('pointsRevoked = 0 khi chưa earn', () => pm.expect(res.data.pointsRevoked).to.eql(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/revoke",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"BK-NEVER-EXISTED-999\"\n}"
            }
          }
        },
        {
          "name": "4.4 Revoke — gọi 2 lần cùng bookingId (idempotent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('pointsRevoked = 0 lần 2', () => pm.expect(res.data.pointsRevoked).to.eql(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/loyalty/revoke",
            "body": {
              "mode": "raw",
